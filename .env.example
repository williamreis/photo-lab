# Porta da API
PORT=8000

# Porta do serviço Nginx (UI em http://localhost:8101)
FRONTEND_PORT=8101

# Fal AI (obrigatório para point/detect)
FAL_KEY=

# Gemini (obrigatório para point/detect)
GEMINI_API_KEY=

# OpenRouter (obrigatório para o agente)
OPENROUTER_API_KEY=

# Modelo com visão (opcional). Ex.: google/gemini-2.0-flash, google/gemini-flash-1.5
AGENT_MODEL=google/gemini-3.1-pro-preview

# Redis (RQ)
# REDIS_URL=redis://localhost:6379/0
